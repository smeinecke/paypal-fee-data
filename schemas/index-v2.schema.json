      "type": "array"
    },
    "generated_at": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Generated At"
    },
    "schema_version": {
      "default": 2,
      "title": "Schema Version",
      "type": "integer"
    }
  },
  "title": "CountryIndex",
  "type": "object"
}
