        "data_url",
        "source_url",
        "country_code"
      ],
      "title": "CountryIndexEntry",
      "type": "object"
    }
  },
  "$id": "https://github.com/smeinecke/paypal-fee-data/schemas/index-v2.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Index of successfully processed countries.",
  "properties": {
    "countries": {
      "items": {
        "$ref": "#/$defs/CountryIndexEntry"
      },
