        },
        "schedule_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Schedule Id"
        },
        "schedule_type": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
