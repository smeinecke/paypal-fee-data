            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Fixed Fee Schedule"
        },
        "id": {
          "title": "Id",
          "type": "string"
        },
        "international_surcharge_schedule": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "International Surcharge Schedule"
        },
        "label": {
