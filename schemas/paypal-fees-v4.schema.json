    "TransactionFeeRule": {
      "additionalProperties": false,
      "description": "A single product-specific transaction fee rule.\n\n``id`` identifies the payment product family. ``variant_id`` distinguishes\nmultiple legitimate pricing variants for the same product (e.g. special\nversus default alternative payment methods). Both fields participate in\nthe stable rule identity key.\n\n``calculation_status`` describes whether and how the rule can be used by a\nfee calculator. ``calculable`` rules carry at least one usable fee\ncomponent; other states preserve source rows for review without exposing\nthem as ready-to-use rates.",
      "properties": {
        "calculation_status": {
          "default": "calculable",
          "title": "Calculation Status",
          "type": "string"
        },
        "conditions": {
          "additionalProperties": true,
          "title": "Conditions",
          "type": "object"
