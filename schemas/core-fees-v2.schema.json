{
  "$defs": {
    "CommercialFee": {
      "additionalProperties": false,
      "description": "Standard commercial transaction fee.",
      "properties": {
        "fixed_fee_reference": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Fixed Fee Reference"
        },
        "percentage": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Percentage"
        }
      },
      "title": "CommercialFee",
      "type": "object"
    },
    "CurrencyConversion": {
      "additionalProperties": false,
      "description": "Currency conversion spread.",
      "properties": {
        "spread_percentage": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Spread Percentage"
        }
      },
      "title": "CurrencyConversion",
      "type": "object"
    },
    "FixedFees": {
      "additionalProperties": false,
      "description": "Fixed fees by received currency.",
      "properties": {
        "amount": {
          "title": "Amount",
          "type": "string"
        },
        "currency": {
          "title": "Currency",
          "type": "string"
        }
      },
      "required": [
        "currency",
        "amount"
      ],
      "title": "FixedFees",
      "type": "object"
    },
    "InternationalSurcharge": {
      "additionalProperties": false,
      "description": "International payer-region surcharge.",
      "properties": {
        "percentage_points": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Percentage Points"
        },
        "region": {
          "title": "Region",
          "type": "string"
        }
      },
      "required": [
        "region"
      ],
      "title": "InternationalSurcharge",
      "type": "object"
    },
    "PublicCoreFeeEntry": {
      "additionalProperties": false,
      "description": "A single country's confidently derived core fees (public).",
      "properties": {
        "country_code": {
          "readOnly": true,
          "title": "Country Code",
          "type": "string"
        },
        "derived": {
          "$ref": "#/$defs/PublicDerivedFees"
        },
        "derived_status": {
          "title": "Derived Status",
          "type": "string"
        },
        "iso_country_code": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Iso Country Code"
        },
        "paypal_market_code": {
          "title": "Paypal Market Code",
          "type": "string"
        }
      },
      "required": [
        "paypal_market_code",
        "derived_status",
        "derived",
        "country_code"
      ],
      "title": "PublicCoreFeeEntry",
      "type": "object"
    },
    "PublicDerivedFees": {
      "additionalProperties": false,
      "description": "Public derived core fees without classifier diagnostics.",
      "properties": {
        "chargeback": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Chargeback"
        },
        "commercial_fixed_fees": {
          "items": {
            "$ref": "#/$defs/FixedFees"
          },
          "title": "Commercial Fixed Fees",
          "type": "array"
        },
        "currency_conversion": {
          "anyOf": [
            {
              "$ref": "#/$defs/CurrencyConversion"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "currency_conversion_exposed": {
          "default": false,
          "title": "Currency Conversion Exposed",
          "type": "boolean"
        },
        "dispute": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Dispute"
        },
        "donations": {
          "anyOf": [
            {
              "$ref": "#/$defs/CommercialFee"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "goods_and_services": {
          "anyOf": [
            {
              "$ref": "#/$defs/CommercialFee"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "international_surcharge_exposed": {
          "default": false,
          "title": "International Surcharge Exposed",
          "type": "boolean"
        },
        "international_surcharges": {
          "items": {
            "$ref": "#/$defs/InternationalSurcharge"
          },
          "title": "International Surcharges",
          "type": "array"
        },
        "micropayments": {
          "anyOf": [
            {
              "$ref": "#/$defs/CommercialFee"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "nonprofit": {
          "anyOf": [
            {
              "$ref": "#/$defs/CommercialFee"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "standard_commercial": {
          "anyOf": [
            {
              "$ref": "#/$defs/CommercialFee"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "status": {
          "default": "unclassified",
          "title": "Status",
          "type": "string"
        }
      },
      "title": "PublicDerivedFees",
      "type": "object"
    }
  },
  "$id": "https://github.com/smeinecke/paypal-fee-data/schemas/core-fees-v2.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Consolidated core fees across all countries.",
  "properties": {
    "countries": {
      "items": {
        "$ref": "#/$defs/PublicCoreFeeEntry"
      },
      "title": "Countries",
      "type": "array"
    },
    "generated_at": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Generated At"
    },
    "schema_version": {
      "default": 2,
      "title": "Schema Version",
      "type": "integer"
    }
  },
  "title": "CoreFees",
  "type": "object"
}
