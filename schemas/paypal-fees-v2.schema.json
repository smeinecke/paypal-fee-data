        "fixed_fee_reference": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Fixed Fee Reference"
        },
        "percentage": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Percentage"
        }
      },
      "title": "CommercialFee",
      "type": "object"
    },
    "CurrencyConversion": {
      "additionalProperties": false,
      "description": "Currency conversion spread.",
