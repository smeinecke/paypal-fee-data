  "$id": "https://github.com/smeinecke/paypal-fee-data/schemas/paypal-fees-v2.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Public consumer-facing country output.",
  "properties": {
    "derived": {
      "$ref": "#/$defs/PublicDerivedFees"
    },
    "generated_at": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Generated At"
    },
    "market": {
      "$ref": "#/$defs/Market"
    },
    "schema_version": {
      "default": 2,
      "title": "Schema Version",
      "type": "integer"
    },
    "sections": {
