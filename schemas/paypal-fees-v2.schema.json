          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Uri"
        }
      },
      "title": "Link",
      "type": "object"
    },
    "Market": {
      "additionalProperties": false,
      "description": "A discovered PayPal market/country.\n\nPayPal market codes (e.g. ``C2`` for China) are kept separate from ISO\n3166-1 alpha-2 country codes. The ``country_code`` property is preserved\nfor backward compatibility and returns the ISO code when known, otherwise\nthe raw PayPal market code.",
      "properties": {
        "country_code": {
          "readOnly": true,
          "title": "Country Code",
          "type": "string"
        },
        "country_name": {
          "title": "Country Name",
          "type": "string"
        },
        "iso_country_code": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Iso Country Code"
        },
        "languages": {
          "items": {
            "$ref": "#/$defs/Language"
          },
          "title": "Languages",
          "type": "array"
        },
        "locale": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Locale"
        },
        "paypal_market_code": {
          "title": "Paypal Market Code",
          "type": "string"
        },
        "preferred_language": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Preferred Language"
        },
        "region": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Region"
        },
        "url_prefix": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Url Prefix"
        },
        "url_slug": {
          "readOnly": true,
          "title": "Url Slug",
          "type": "string"
        }
      },
      "required": [
        "paypal_market_code",
        "country_name",
        "country_code",
        "url_slug"
      ],
      "title": "Market",
      "type": "object"
    },
    "PublicCell": {
      "additionalProperties": false,
