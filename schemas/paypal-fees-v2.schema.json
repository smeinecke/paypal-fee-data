        "$ref": "#/$defs/PublicTable"
      },
      "title": "Tables",
      "type": "array"
    },
    "warnings": {
      "items": {
        "$ref": "#/$defs/PublicWarning"
      },
      "title": "Warnings",
      "type": "array"
    }
  },
  "required": [
    "market",
    "source",
    "derived"
  ],
  "title": "PublicCountryOutput",
  "type": "object"
