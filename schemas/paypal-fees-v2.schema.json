        "spread_percentage": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Spread Percentage"
        }
      },
      "title": "CurrencyConversion",
      "type": "object"
    },
    "FixedFees": {
      "additionalProperties": false,
