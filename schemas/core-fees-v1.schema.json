{
  "$defs": {
    "CoreFeeDerived": {
      "additionalProperties": false,
      "description": "Compact derived fee result for core-fees.json.",
      "properties": {
        "currency_conversion": {
          "anyOf": [
            {
              "$ref": "#/$defs/CurrencyConversion"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "fixed_fee_schedules": {
          "additionalProperties": {
            "$ref": "#/$defs/CoreFeeFixedFeeSchedule"
          },
          "title": "Fixed Fee Schedules",
          "type": "object"
        },
        "international_surcharge_schedules": {
          "additionalProperties": {
            "$ref": "#/$defs/CoreFeeInternationalSurchargeSchedule"
          },
          "title": "International Surcharge Schedules",
          "type": "object"
        },
        "maximum_fee_schedules": {
          "additionalProperties": {
            "$ref": "#/$defs/CoreFeeFixedFeeSchedule"
          },
          "title": "Maximum Fee Schedules",
          "type": "object"
        },
        "status": {
          "default": "unclassified",
          "title": "Status",
          "type": "string"
        },
        "transaction_fee_rules": {
          "items": {
            "$ref": "#/$defs/CoreFeeRule"
          },
          "title": "Transaction Fee Rules",
          "type": "array"
        }
      },
      "title": "CoreFeeDerived",
      "type": "object"
    },
    "CoreFeeFixedFeeSchedule": {
      "additionalProperties": false,
      "description": "Compact fixed fee schedule used in core-fees.json (no provenance).",
      "properties": {
        "entries": {
          "additionalProperties": {
            "type": "string"
          },
          "title": "Entries",
          "type": "object"
        }
      },
      "title": "CoreFeeFixedFeeSchedule",
      "type": "object"
    },
    "CoreFeeInternationalSurchargeSchedule": {
      "additionalProperties": false,
      "description": "Compact international surcharge schedule used in core-fees.json (no provenance).",
      "properties": {
        "entries": {
          "items": {
            "$ref": "#/$defs/InternationalSurchargeScheduleEntry"
          },
          "title": "Entries",
          "type": "array"
        }
      },
      "title": "CoreFeeInternationalSurchargeSchedule",
      "type": "object"
    },
    "CoreFeeRateReference": {
      "additionalProperties": false,
      "description": "Compact rate reference without provenance.",
      "properties": {
        "reference": {
          "title": "Reference",
          "type": "string"
        },
        "resolved_rate": {
          "anyOf": [
            {
              "$ref": "#/$defs/CoreFeeResolvedRate"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "required": [
        "reference"
      ],
      "title": "CoreFeeRateReference",
      "type": "object"
    },
    "CoreFeeResolvedRate": {
      "additionalProperties": false,
      "description": "Compact resolved rate without provenance.",
      "properties": {
        "fixed_fee_schedule": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Fixed Fee Schedule"
        },
        "international_surcharge_schedule": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "International Surcharge Schedule"
        },
        "maximum_fee_schedule": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Maximum Fee Schedule"
        },
        "percentage": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Percentage"
        },
        "rule_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Rule Id"
        }
      },
      "title": "CoreFeeResolvedRate",
      "type": "object"
    },
    "CoreFeeRule": {
      "additionalProperties": false,
      "description": "Compact transaction fee rule used in core-fees.json (no provenance).",
      "properties": {
        "calculation_status": {
          "default": "calculable",
          "title": "Calculation Status",
          "type": "string"
        },
        "conditions": {
          "additionalProperties": true,
          "title": "Conditions",
          "type": "object"
        },
        "fee_components": {
          "items": {
            "$ref": "#/$defs/FeeComponent"
          },
          "title": "Fee Components",
          "type": "array"
        },
        "fixed_fee_schedule": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Fixed Fee Schedule"
        },
        "id": {
          "title": "Id",
          "type": "string"
        },
        "international_surcharge_schedule": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "International Surcharge Schedule"
        },
        "label": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Label"
        },
        "maximum_fee_schedule": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Maximum Fee Schedule"
        },
        "percentage": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Percentage"
        },
        "rate_reference": {
          "anyOf": [
            {
              "$ref": "#/$defs/CoreFeeRateReference"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "variant_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Variant Id"
        }
      },
      "required": [
        "id"
      ],
      "title": "CoreFeeRule",
      "type": "object"
    },
    "CurrencyConversion": {
      "additionalProperties": false,
      "description": "Currency conversion spread.",
      "properties": {
        "spread_percentage": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Spread Percentage"
        }
      },
      "title": "CurrencyConversion",
      "type": "object"
    },
    "FeeComponent": {
      "additionalProperties": false,
      "description": "One calculable fee component for a transaction rule.\n\nComponents can represent a percentage, a direct fixed monetary amount, or a\nreference to a schedule.  The ``type`` field determines which other fields\nare meaningful.",
      "properties": {
        "amount": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Amount"
        },
        "currency": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Currency"
        },
        "operator": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Operator"
        },
        "schedule_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Schedule Id"
        },
        "type": {
          "title": "Type",
          "type": "string"
        },
        "value": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Value"
        }
      },
      "required": [
        "type"
      ],
      "title": "FeeComponent",
      "type": "object"
    },
    "InternationalSurchargeScheduleEntry": {
      "additionalProperties": false,
      "description": "One region entry in an international surcharge schedule.",
      "properties": {
        "payer_region": {
          "title": "Payer Region",
          "type": "string"
        },
        "percentage_points": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Percentage Points"
        }
      },
      "required": [
        "payer_region"
      ],
      "title": "InternationalSurchargeScheduleEntry",
      "type": "object"
    },
    "PublicCoreFeeEntry": {
      "additionalProperties": false,
      "description": "A single country's confidently derived core fees (public).",
      "properties": {
        "country_code": {
          "readOnly": true,
          "title": "Country Code",
          "type": "string"
        },
        "derived": {
          "$ref": "#/$defs/CoreFeeDerived"
        },
        "derived_status": {
          "title": "Derived Status",
          "type": "string"
        },
        "iso_country_code": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Iso Country Code"
        },
        "paypal_market_code": {
          "title": "Paypal Market Code",
          "type": "string"
        }
      },
      "required": [
        "paypal_market_code",
        "derived_status",
        "derived",
        "country_code"
      ],
      "title": "PublicCoreFeeEntry",
      "type": "object"
    }
  },
  "$id": "https://github.com/smeinecke/paypal-fee-data/schemas/core-fees-v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Consolidated core fees across all countries.",
  "properties": {
    "countries": {
      "items": {
        "$ref": "#/$defs/PublicCoreFeeEntry"
      },
      "title": "Countries",
      "type": "array"
    },
    "generated_at": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Generated At"
    },
    "schema_version": {
      "default": 1,
      "title": "Schema Version",
      "type": "integer"
    }
  },
  "title": "CoreFees",
  "type": "object"
}
