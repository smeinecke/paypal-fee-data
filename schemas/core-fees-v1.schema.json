{
  "$defs": {
    "CommercialFee": {
      "description": "Standard commercial transaction fee.",
      "properties": {
        "fixed_fee_reference": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Fixed Fee Reference"
        },
        "percentage": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Percentage"
        }
      },
      "title": "CommercialFee",
      "type": "object"
    },
    "CoreFeeEntry": {
      "description": "A single country's confidently derived core fees.",
      "properties": {
        "country_code": {
          "title": "Country Code",
          "type": "string"
        },
        "derived": {
          "$ref": "#/$defs/DerivedFees"
        },
        "derived_status": {
          "title": "Derived Status",
          "type": "string"
        }
      },
      "required": [
        "country_code",
        "derived_status",
        "derived"
      ],
      "title": "CoreFeeEntry",
      "type": "object"
    },
    "CurrencyConversion": {
      "description": "Currency conversion spread.",
      "properties": {
        "spread_percentage": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Spread Percentage"
        }
      },
      "title": "CurrencyConversion",
      "type": "object"
    },
    "DerivedFees": {
      "description": "Derived core fees with confidence status.",
      "properties": {
        "chargeback": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Chargeback"
        },
        "commercial_fixed_fees": {
          "items": {
            "$ref": "#/$defs/FixedFees"
          },
          "title": "Commercial Fixed Fees",
          "type": "array"
        },
        "currency_conversion": {
          "anyOf": [
            {
              "$ref": "#/$defs/CurrencyConversion"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "dispute": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Dispute"
        },
        "donations": {
          "anyOf": [
            {
              "$ref": "#/$defs/CommercialFee"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "goods_and_services": {
          "anyOf": [
            {
              "$ref": "#/$defs/CommercialFee"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "international_surcharges": {
          "items": {
            "$ref": "#/$defs/InternationalSurcharge"
          },
          "title": "International Surcharges",
          "type": "array"
        },
        "micropayments": {
          "anyOf": [
            {
              "$ref": "#/$defs/CommercialFee"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "nonprofit": {
          "anyOf": [
            {
              "$ref": "#/$defs/CommercialFee"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "standard_commercial": {
          "anyOf": [
            {
              "$ref": "#/$defs/CommercialFee"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "status": {
          "default": "unclassified",
          "title": "Status",
          "type": "string"
        },
        "unclassified_sections": {
          "items": {
            "type": "string"
          },
          "title": "Unclassified Sections",
          "type": "array"
        }
      },
      "title": "DerivedFees",
      "type": "object"
    },
    "FixedFees": {
      "description": "Fixed fees by received currency.",
      "properties": {
        "amount": {
          "title": "Amount",
          "type": "string"
        },
        "currency": {
          "title": "Currency",
          "type": "string"
        }
      },
      "required": [
        "currency",
        "amount"
      ],
      "title": "FixedFees",
      "type": "object"
    },
    "InternationalSurcharge": {
      "description": "International payer-region surcharge.",
      "properties": {
        "percentage_points": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Percentage Points"
        },
        "region": {
          "title": "Region",
          "type": "string"
        }
      },
      "required": [
        "region"
      ],
      "title": "InternationalSurcharge",
      "type": "object"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "Consolidated core fees across all countries.",
  "properties": {
    "countries": {
      "items": {
        "$ref": "#/$defs/CoreFeeEntry"
      },
      "title": "Countries",
      "type": "array"
    },
    "schema_version": {
      "default": 1,
      "title": "Schema Version",
      "type": "integer"
    }
  },
  "title": "CoreFees",
  "type": "object"
}
