{
  "$defs": {
    "CurrencyConversion": {
      "additionalProperties": false,
      "description": "Currency conversion spread.",
      "properties": {
        "spread_percentage": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Spread Percentage"
        }
      },
      "title": "CurrencyConversion",
      "type": "object"
    },
    "FixedFees": {
      "additionalProperties": false,
      "description": "Fixed fees by received currency.",
      "properties": {
        "amount": {
          "title": "Amount",
          "type": "string"
        },
        "currency": {
          "title": "Currency",
          "type": "string"
        }
      },
      "required": [
        "currency",
        "amount"
      ],
      "title": "FixedFees",
      "type": "object"
    },
    "InternationalSurcharge": {
      "additionalProperties": false,
      "description": "International payer-region surcharge.",
      "properties": {
        "percentage_points": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Percentage Points"
        },
        "region": {
          "title": "Region",
          "type": "string"
        }
      },
      "required": [
        "region"
      ],
      "title": "InternationalSurcharge",
      "type": "object"
    },
    "PublicCommercialFee": {
      "additionalProperties": false,
      "description": "Consumer-facing commercial fee without internal table references.",
      "properties": {
        "percentage": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Percentage"
        }
      },
      "title": "PublicCommercialFee",
      "type": "object"
    },
    "PublicDerivedFees": {
      "additionalProperties": false,
      "description": "Public derived core fees without classifier diagnostics.",
      "properties": {
        "chargeback": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Chargeback"
        },
        "commercial_fixed_fees": {
          "items": {
            "$ref": "#/$defs/FixedFees"
          },
          "title": "Commercial Fixed Fees",
          "type": "array"
        },
        "currency_conversion": {
          "anyOf": [
            {
              "$ref": "#/$defs/CurrencyConversion"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "currency_conversion_exposed": {
          "default": false,
          "title": "Currency Conversion Exposed",
          "type": "boolean"
        },
        "dispute": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Dispute"
        },
        "donations": {
          "anyOf": [
            {
              "$ref": "#/$defs/PublicCommercialFee"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "goods_and_services": {
          "anyOf": [
            {
              "$ref": "#/$defs/PublicCommercialFee"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "international_surcharge_exposed": {
          "default": false,
          "title": "International Surcharge Exposed",
          "type": "boolean"
        },
        "international_surcharges": {
          "items": {
            "$ref": "#/$defs/InternationalSurcharge"
          },
          "title": "International Surcharges",
          "type": "array"
        },
        "micropayments": {
          "anyOf": [
            {
              "$ref": "#/$defs/PublicCommercialFee"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "nonprofit": {
          "anyOf": [
            {
              "$ref": "#/$defs/PublicCommercialFee"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "standard_commercial": {
          "anyOf": [
            {
              "$ref": "#/$defs/PublicCommercialFee"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "status": {
          "default": "unclassified",
          "title": "Status",
          "type": "string"
        }
      },
      "title": "PublicDerivedFees",
      "type": "object"
    },
    "PublicMarket": {
      "additionalProperties": false,
      "description": "Consumer-facing market identity for a country fee result.",
      "properties": {
        "country_name": {
          "title": "Country Name",
          "type": "string"
        },
        "iso_country_code": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Iso Country Code"
        },
        "locale": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Locale"
        },
        "paypal_market_code": {
          "title": "Paypal Market Code",
          "type": "string"
        }
      },
      "required": [
        "paypal_market_code",
        "country_name"
      ],
      "title": "PublicMarket",
      "type": "object"
    }
  },
  "$id": "https://github.com/smeinecke/paypal-fee-data/schemas/paypal-fees-v3.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Compact public consumer-facing country fee result.",
  "properties": {
    "derived": {
      "$ref": "#/$defs/PublicDerivedFees"
    },
    "generated_at": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Generated At"
    },
    "market": {
      "$ref": "#/$defs/PublicMarket"
    },
    "schema_version": {
      "default": 3,
      "title": "Schema Version",
      "type": "integer"
    }
  },
  "required": [
    "market",
    "derived"
  ],
  "title": "PublicCountryOutput",
  "type": "object"
}
