{
  "$defs": {
    "Language": {
      "additionalProperties": false,
      "description": "A supported language for a market.",
      "properties": {
        "code": {
          "title": "Code",
          "type": "string"
        },
        "name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Name"
        }
      },
      "required": [
        "code"
      ],
      "title": "Language",
      "type": "object"
    },
    "Market": {
      "additionalProperties": false,
      "description": "A discovered PayPal market/country.\n\nPayPal market codes (e.g. ``C2`` for China) are kept separate from ISO\n3166-1 alpha-2 country codes. The ``country_code`` property is preserved\nfor backward compatibility and returns the ISO code when known, otherwise\nthe raw PayPal market code.",
      "properties": {
        "paypal_market_code": {
          "title": "Paypal Market Code",
          "type": "string"
        },
        "country_name": {
          "title": "Country Name",
          "type": "string"
        },
        "iso_country_code": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Iso Country Code"
        },
        "region": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Region"
        },
        "locale": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Locale"
        },
        "languages": {
          "items": {
            "$ref": "#/$defs/Language"
          },
          "title": "Languages",
          "type": "array"
        },
        "url_prefix": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Url Prefix"
        },
        "preferred_language": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Preferred Language"
        },
        "country_code": {
          "readOnly": true,
          "title": "Country Code",
          "type": "string"
        },
        "url_slug": {
          "readOnly": true,
          "title": "Url Slug",
          "type": "string"
        }
      },
      "required": [
        "paypal_market_code",
        "country_name",
        "country_code",
        "url_slug"
      ],
      "title": "Market",
      "type": "object"
    },
    "UnsupportedCountry": {
      "additionalProperties": false,
      "description": "A market without a discoverable public fee page.",
      "properties": {
        "paypal_market_code": {
          "title": "Paypal Market Code",
          "type": "string"
        },
        "iso_country_code": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Iso Country Code"
        },
        "country_name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Country Name"
        },
        "tested_urls": {
          "items": {
            "type": "string"
          },
          "title": "Tested Urls",
          "type": "array"
        },
        "reason": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Reason"
        },
        "first_confirmed_at": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "First Confirmed At"
        },
        "last_confirmed_at": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Last Confirmed At"
        },
        "last_status": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Last Status"
        },
        "temporary": {
          "default": false,
          "title": "Temporary",
          "type": "boolean"
        },
        "country_code": {
          "readOnly": true,
          "title": "Country Code",
          "type": "string"
        }
      },
      "required": [
        "paypal_market_code",
        "country_code"
      ],
      "title": "UnsupportedCountry",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "Discovered country manifest.",
  "properties": {
    "schema_version": {
      "default": 1,
      "title": "Schema Version",
      "type": "integer"
    },
    "generated_at": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Generated At"
    },
    "markets": {
      "items": {
        "$ref": "#/$defs/Market"
      },
      "title": "Markets",
      "type": "array"
    },
    "unsupported": {
      "items": {
        "$ref": "#/$defs/UnsupportedCountry"
      },
      "title": "Unsupported",
      "type": "array"
    },
    "fee_page_urls": {
      "additionalProperties": {
        "type": "string"
      },
      "title": "Fee Page Urls",
      "type": "object"
    }
  },
  "title": "CountryManifest",
  "type": "object",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/smeinecke/paypal-fee-data/schemas/manifest-v1.schema.json"
}
